# Playwright E2Eテスト用環境変数（.env.test にコピーして実際の値を設定）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
E2E_MEMBER_EMAIL=e2e-member@test.example.com
E2E_MEMBER_PASSWORD=TestPassword123!
E2E_ADMIN_EMAIL=e2e-admin@test.example.com
E2E_ADMIN_PASSWORD=TestPassword123!
# CI環境のみ（ローカルでは不要）
# PLAYWRIGHT_BASE_URL=https://your-vercel-preview.vercel.app
